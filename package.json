{
  "name": "url-shortener",
  "version": "1.0.0",
  "description": "URL shortener backend — learning project",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "package:lambda": "node scripts/package-lambda.mjs",
    "test:unit": "node --test tests/*.test.js",
    "test:e2e": "npx playwright test e2e/shortener.spec.js --project=chromium",
    "test:smoke": "npx playwright test e2e/shortener.spec.js --project=chromium",
    "test": "npm run test:unit && npm run test:e2e",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0"
  },
  "keywords": [
    "url-shortener",
    "backend"
  ],
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.840.0",
    "@aws-sdk/lib-dynamodb": "^3.840.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "eslint": "^9.39.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^16.5.0",
    "nodemon": "^3.1.14"
  }
}
