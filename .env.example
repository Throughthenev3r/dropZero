PORT=3000
BASE_URL=http://localhost:3000

# --- Local development (DynamoDB Local) ---
DYNAMODB_ENDPOINT=http://localhost:8000
LINKS_TABLE=links
CLICK_EVENTS_TABLE=click_events
LINK_TTL_DAYS=30
CLICK_EVENT_TTL_DAYS=37

# --- AWS (Terraform / Lambda) ---
# Paste IAM user keys here. Do not commit .env
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# For AWS deploy: remove or comment DYNAMODB_ENDPOINT above.
# Terraform creates tables: url-shortener-links, url-shortener-click-events
